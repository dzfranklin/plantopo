# Sample values so that the production build can be run locally
# The deployment does not use .env files

LOG_LEVEL=info
APP_URL=http://localhost:3030
BETTER_AUTH_SECRET=not-the-actual-production-secret
DATABASE_URL=postgres://postgres@host.docker.internal/plantopo_prod
TILE_CACHE_DIR=/tmp/tile-cache
VALHALLA=https://valhalla.reindeer-neon.ts.net
PHOTON=https://photon.reindeer-neon.ts.net
