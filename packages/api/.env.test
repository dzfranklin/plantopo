S3_IMAGE_BUCKET=plantopo-images-test
S3_IMAGE_ACCESS_KEY_ID=fake-access-key-id
S3_IMAGE_SECRET_ACCESS_KEY=fake-secret-access-key

IMGPROXY_KEY=fake-imgproxy-key
IMGPROXY_SALT=fake-imgproxy-salt
