[Unit]
Description=PlanTopo API
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/dzfranklin/plantopo-api:latest
ContainerName=plantopo-api
PublishPort=3030:4000
EnvironmentFile=/etc/plantopo/api.env
Network=plantopo.network

[Service]
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
