{
  "name": "plantopo",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dzfranklin/plantopo.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "NODE_ENV=development tsx packages/api/src/server.ts",
    "scratch": "NODE_ENV=development tsx watch packages/api/src/.scratch.local.ts",
    "dev:android-devtools": "adb reverse tcp:8097 tcp:8097 && react-devtools",
    "db:generate": "NODE_ENV=development tsx scripts/with-api-env.ts drizzle-kit generate",
    "db:migrate": "NODE_ENV=development tsx packages/api/src/migrate.ts",
    "db:studio": "NODE_ENV=development tsx scripts/with-api-env.ts drizzle-kit studio",
    "local-prod": "bash scripts/local-prod.sh",
    "check": "tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p packages/api/tsconfig.json && tsc --noEmit -p packages/web/tsconfig.json && prettier --write --log-level warn . && eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "[ \"$npm_command\" = \"ci\" ] || husky"
  },
  "dependencies": {
    "@pt/web": "^0.0.0",
    "@types/geojson": "^7946.0.16",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "geodesy": "^2.4.0",
    "react-devtools": "^7.0.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/geodesy": "^2.2.8",
    "@types/node": "^24.12.0",
    "@types/pngjs": "^6.0.5",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "pino-abstract-transport": "^3.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.1"
  }
}
